# Local edge-function env. Copy to supabase/functions/.env and fill in real values.
# Auto-loaded by `supabase start` / `supabase functions serve` for every function.
#
# In production these values come from Supabase project secrets — push them with:
#   supabase secrets set --env-file ./supabase/.env

# Resend — used by the send-result-email edge function.
RESEND_API_KEY=re_your_resend_api_key
