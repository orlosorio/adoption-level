# Supabase project secrets. Copy to supabase/.env and fill in real values.
# Used to push secrets to the remote project:
#   supabase secrets set --env-file ./supabase/.env
#
# NOTE: this file is NOT auto-loaded by `supabase start` for local serving.
# For local edge functions, also keep a copy at supabase/functions/.env
# (which IS auto-loaded). See supabase/functions/.env.example.

# Resend — used by the send-result-email edge function.
RESEND_API_KEY=re_your_resend_api_key
